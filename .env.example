# DeepRead 配置示例 - 复制本文件为 .env 并填入实际值
# DeepRead Configuration Example - Copy to .env and fill in real values

# API 密钥（必填）
API_KEY=your-api-key-here

# API 接入端点 - 任何兼容 OpenAI SDK 的服务均可（必填）
# 示例（Anthropic）: https://api.anthropic.com/v1
API_BASE_URL=https://api.anthropic.com/v1

# 模型名称（必填）
# 示例（Anthropic）: claude-3-5-sonnet-20241022
MODEL=claude-3-5-sonnet-20241022
